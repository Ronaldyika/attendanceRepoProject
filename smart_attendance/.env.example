# ============================================================
# Smart Attendance System – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Django Core
DJANGO_SECRET_KEY=replace-with-a-long-random-string-at-least-50-chars
DJANGO_DEBUG=False
ALLOWED_HOSTS=*,localhost,127.0.0.1

# Database (PostgreSQL for production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=smart_attendance_db
DB_USER=attendance_user
DB_PASSWORD=your-strong-db-password
DB_HOST=localhost
DB_PORT=5432


# QR Code Settings
QR_CODE_VALIDITY_SECONDS=10        # 10 seconds 
CLOCK_SKEW_TOLERANCE_SECONDS=5    # 5 seconds
SYNC_PENDING_ALERT_HOURS=6
